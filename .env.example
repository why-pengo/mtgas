# ─── Django ────────────────────────────────────────────────────────────────────
# Generate a strong secret key for production, e.g.:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=change-me-in-production

DJANGO_DEBUG=True

# Comma-separated list of additional allowed hosts (localhost/127.0.0.1 always included)
DJANGO_ALLOWED_HOSTS=

# ─── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=mtgas
POSTGRES_USER=mtgas
POSTGRES_PASSWORD=mtgas_dev_password
# POSTGRES_HOST is set to the Docker service name by docker-compose.yml;
# override here only when connecting to a non-Docker Postgres instance.
# POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ─── Celery / Redis ────────────────────────────────────────────────────────────
# Points to the Redis service name defined in docker-compose.yml
CELERY_BROKER_URL=redis://redis:6379/0

# ─── Timezone (optional) ──────────────────────────────────────────────────────
# TIME_ZONE=America/New_York
